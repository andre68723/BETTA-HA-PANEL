{
    "version": 3,
    "cmakeMinimumRequired": { "major": 3, "minor": 21, "patch": 0 },
    "configurePresets": [
        {
            "name": "panel4",
            "displayName": "Panel 4\" 720x720 (smart86 base)",
            "description": "Build for the original 4-inch 720x720 round panel.",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build-panel4",
            "cacheVariables": {
                "SDKCONFIG_DEFAULTS": "sdkconfig.defaults;sdkconfig.defaults.panel4",
                "SDKCONFIG": "${sourceDir}/sdkconfig.panel4"
            }
        },
        {
            "name": "panel10",
            "displayName": "Panel 10.1\" 1280x800 (betta large)",
            "description": "Build for the 10.1-inch 1280x800 MIPI-DSI panel.",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build-panel10",
            "cacheVariables": {
                "SDKCONFIG_DEFAULTS": "sdkconfig.defaults;sdkconfig.defaults.panel10",
                "SDKCONFIG": "${sourceDir}/sdkconfig.panel10"
            }
        },
        {
            "name": "panels3",
            "displayName": "Panel S3 4\" 480x480 (Guition CYD 4848S040)",
            "description": "Build for the Guition CYD ESP32-S3 4848S040 (RGB ST7701S, native Wi-Fi).",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build-panels3",
            "cacheVariables": {
                "SDKCONFIG_DEFAULTS": "sdkconfig.defaults.s3;sdkconfig.defaults.panels3",
                "SDKCONFIG": "${sourceDir}/sdkconfig.panels3"
            }
        },
        {
            "name": "paneljc",
            "displayName": "Panel JC 10.1\" 800x1280 (Guition JC8012P4A1)",
            "description": "Build for the Guition JC8012P4A1 (ESP32-P4 + JD9365 MIPI-DSI, GSL3680 touch, ESP-Hosted C6 Wi-Fi).",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build-paneljc",
            "cacheVariables": {
                "IDF_TARGET": "esp32p4",
                "SDKCONFIG_DEFAULTS": "sdkconfig.defaults;sdkconfig.defaults.paneljc",
                "SDKCONFIG": "${sourceDir}/sdkconfig.paneljc"
            }
        }
    ]
}
