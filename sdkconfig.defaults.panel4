#
# Panel variant overlay: 4" 720x720 (original smart86 hardware).
# Apply together with the common sdkconfig.defaults via
#   idf.py -D SDKCONFIG_DEFAULTS="sdkconfig.defaults;sdkconfig.defaults.panel4" ...
# or the CMake preset "panel4" (see CMakePresets.json).
CONFIG_APP_PANEL_VARIANT_4INCH_720=y
# CONFIG_APP_PANEL_VARIANT_10INCH_1280 is not set

# --- BSP display/touch: Waveshare ESP32-P4-WIFI6-Touch-LCD-4B (800x800 3.4") ---
CONFIG_BSP_LCD_TYPE_800_800_3_4_INCH=y
CONFIG_ESP_LCD_TOUCH_MAX_POINTS=5
